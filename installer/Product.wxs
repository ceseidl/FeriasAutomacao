<?xml version="1.0" encoding="UTF-8"?>
<!--
  Instalador MSI do Ferias Automacao.

  Escopo: per-user (instala em %LocalAppData%\Programs\FeriasAutomacao,
  sem prompt de UAC). Bom pra ambiente corporativo onde o usuario nao
  costuma ter direito de admin.

  UI: WixUI_FeatureTree - mostra uma arvore de features onde o usuario
  escolhe o que quer instalar (incluindo onde criar atalhos).

  Build: installer\build.ps1 (envolve "wix build" da WiX 4 toolset).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
      Name="Ferias Automacao"
      Manufacturer="Carlos Seidl"
      Version="1.0.0"
      ProductCode="*"
      UpgradeCode="1278BE29-7DA4-4021-8DB9-CA6F717F49C0"
      Scope="perUser"
      Compressed="yes"
      InstallerVersion="500">

    <SummaryInformation
        Description="Gerador de relatorio de planejamento de ferias"
        Manufacturer="Carlos Seidl" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Icone de Add/Remove Programs -->
    <Icon Id="AppIcon.exe" SourceFile="..\assets\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.exe" />
    <Property Id="ARPHELPLINK"   Value="https://github.com/ceseidl/FeriasAutomacao" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/ceseidl/FeriasAutomacao" />

    <!-- Permite instalar por cima de uma versao mais antiga -->
    <MajorUpgrade
        DowngradeErrorMessage="Uma versao mais nova do Ferias Automacao ja esta instalada."
        AllowSameVersionUpgrades="yes" />

    <!-- UI com tela dedicada pra escolher a pasta de instalacao.
         WixUI_InstallDir mostra: Welcome -> License -> InstallDir (com
         botao "Browse..." pra mudar a pasta) -> VerifyReady -> Finish.
         A pasta default e LocalAppDataFolder\Programs\FeriasAutomacao
         (per-user, sem prompt de UAC), mas o usuario pode trocar pra
         qualquer outra pasta com permissao de escrita. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- TODO: checkbox "Iniciar Ferias Automacao agora" no ExitDialog.
         Removido temporariamente. 4 abordagens diferentes nao
         funcionaram (FileRef do .bat, Directory+ExeCommand com
         powershell direto, util:WixSilentExec, cmd.exe /c .bat).
         Ate descobrir o approach certo, o usuario abre manualmente
         pelo atalho do Menu Iniciar ou Desktop apos instalar. -->

    <!-- Feature raiz: aplicativo principal (obrigatorio).
         Filhos: 3 features opcionais pros locais de atalho. Por padrao
         tudo instalado; o usuario pode desmarcar o que nao quer. -->
    <Feature Id="Main"
             Title="Aplicativo Ferias Automacao"
             Description="Arquivos do aplicativo (gui, planilha, manual, recursos). Necessario."
             Level="1"
             AllowAbsent="no"
             Display="expand"
             ConfigurableDirectory="INSTALLFOLDER">
      <ComponentGroupRef Id="AppRootFiles" />
      <ComponentGroupRef Id="AppAssets" />
      <ComponentGroupRef Id="AppBin" />
      <ComponentGroupRef Id="AppDocs" />
      <!-- Atalho do Desktop e OBRIGATORIO. Faz parte da feature Main
           (que tem AllowAbsent="no") em vez de uma sub-feature opcional,
           pra garantir que toda instalacao ganha o atalho na area de
           trabalho do usuario, sem opcao de desmarcar. -->
      <ComponentGroupRef Id="AppShortcutsDesktop" />

      <Feature Id="ShortcutsStartMenu"
               Title="Atalhos no Menu Iniciar"
               Description="Cria atalhos em 'AI R' (Gerar Relatorio, Manual, Pasta de instalacao, Desinstalar). Recomendado."
               Level="1">
        <ComponentGroupRef Id="AppShortcutsStartMenu" />
      </Feature>

      <Feature Id="ShortcutsSendTo"
               Title="Atalho em 'Enviar para'"
               Description="Adiciona 'Ferias Automacao' ao menu 'Enviar para' do clique-direito do Windows. Util pra abrir uma planilha .xlsx direto no app."
               Level="1000">
        <ComponentGroupRef Id="AppShortcutsSendTo" />
      </Feature>
    </Feature>
  </Package>

  <!-- ==================================================
       Estrutura de pastas
       ================================================== -->
  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="FeriasAutomacao">
          <Directory Id="AssetsFolder" Name="assets" />
          <Directory Id="BinFolder"    Name="bin" />
          <Directory Id="DocsFolder"   Name="docs" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <!-- Pasta no Menu Iniciar identificada pela marca da empresa.
           Espaco no lugar da barra ('AI R' em vez de 'AI/R') porque
           Windows nao permite '/' em nome de pasta. -->
      <Directory Id="StartMenuGroup" Name="AI R" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />
    <StandardDirectory Id="SendToFolder" />
  </Fragment>

  <!-- ==================================================
       Arquivos da raiz (gui/executar/template/planilha/etc)
       ================================================== -->
  <Fragment>
    <ComponentGroup Id="AppRootFiles" Directory="INSTALLFOLDER">
      <Component>
        <File Id="AppGuiPs1" Source="..\gui.ps1" KeyPath="yes" />
      </Component>
      <Component>
        <File Source="..\executar.ps1" KeyPath="yes" />
      </Component>
      <Component>
        <File Source="..\template.md" KeyPath="yes" />
      </Component>
      <Component>
        <File Source="..\Ferias-template.xlsx" KeyPath="yes" />
      </Component>
      <Component>
        <File Source="..\LICENSE" Name="LICENSE.txt" KeyPath="yes" />
      </Component>
      <Component>
        <File Id="AppGerarRelatorioBat" Source="..\Gerar Relatorio.bat" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="AppAssets" Directory="AssetsFolder">
      <Component>
        <File Id="AssetIconIco" Source="..\assets\icon.ico" KeyPath="yes" />
      </Component>
      <Component>
        <File Source="..\assets\style.css" KeyPath="yes" />
      </Component>
      <Component>
        <File Source="..\assets\header.html" KeyPath="yes" />
      </Component>
      <Component>
        <File Source="..\assets\mermaid.lua" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="AppBin" Directory="BinFolder">
      <Component>
        <File Source="..\bin\pandoc-installer.msi" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="AppDocs" Directory="DocsFolder">
      <Component>
        <File Source="..\docs\MANUAL.docx" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- ==================================================
       Atalhos: Menu Iniciar
       (per-user precisa de RegistryValue como KeyPath)
       ================================================== -->
  <Fragment>
    <ComponentGroup Id="AppShortcutsStartMenu" Directory="StartMenuGroup">
      <Component Id="ShortcutGerarRelatorio" Guid="*">
        <Shortcut
            Id="ShortcutGerarRelatorioLnk"
            Name="Gerar Relatorio"
            Description="Abre o gerador de planejamento de ferias"
            Target="[System64Folder]WindowsPowerShell\v1.0\powershell.exe"
            Arguments='-ExecutionPolicy Bypass -WindowStyle Hidden -File "[INSTALLFOLDER]gui.ps1"'
            WorkingDirectory="INSTALLFOLDER"
            Icon="AppIcon.exe"
            IconIndex="0" />
        <RemoveFolder Id="RemoveStartMenuGroup" Directory="StartMenuGroup" On="uninstall" />
        <RegistryValue
            Root="HKCU"
            Key="Software\FeriasAutomacao\Shortcuts"
            Name="StartMenu"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>

      <Component Id="ShortcutManual" Guid="*">
        <Shortcut
            Id="ShortcutManualLnk"
            Name="Manual do usuario"
            Description="Abre o manual do Ferias Automacao"
            Target="[INSTALLFOLDER]docs\MANUAL.docx"
            WorkingDirectory="DocsFolder" />
        <RegistryValue
            Root="HKCU"
            Key="Software\FeriasAutomacao\Shortcuts"
            Name="StartMenuManual"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>

      <Component Id="ShortcutPasta" Guid="*">
        <Shortcut
            Id="ShortcutPastaLnk"
            Name="Pasta de instalacao"
            Description="Abre a pasta onde o Ferias Automacao foi instalado"
            Target="[INSTALLFOLDER]"
            WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue
            Root="HKCU"
            Key="Software\FeriasAutomacao\Shortcuts"
            Name="StartMenuPasta"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>

      <!-- Atalho de desinstalar: dispara msiexec /x com o ProductCode
           do app, abrindo o assistente padrao do Windows pra remover. -->
      <Component Id="ShortcutDesinstalar" Guid="*">
        <Shortcut
            Id="ShortcutDesinstalarLnk"
            Name="Desinstalar Ferias Automacao"
            Description="Remove o Ferias Automacao deste computador"
            Target="[System64Folder]msiexec.exe"
            Arguments='/x "[ProductCode]"' />
        <RegistryValue
            Root="HKCU"
            Key="Software\FeriasAutomacao\Shortcuts"
            Name="StartMenuDesinstalar"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- ==================================================
       Atalho: Area de Trabalho
       ================================================== -->
  <Fragment>
    <ComponentGroup Id="AppShortcutsDesktop" Directory="DesktopFolder">
      <Component Id="ShortcutDesktop" Guid="*">
        <Shortcut
            Id="ShortcutDesktopLnk"
            Name="Gerar Relatorio"
            Description="Abre o gerador de planejamento de ferias"
            Target="[System64Folder]WindowsPowerShell\v1.0\powershell.exe"
            Arguments='-ExecutionPolicy Bypass -WindowStyle Hidden -File "[INSTALLFOLDER]gui.ps1"'
            WorkingDirectory="INSTALLFOLDER"
            Icon="AppIcon.exe"
            IconIndex="0" />
        <RegistryValue
            Root="HKCU"
            Key="Software\FeriasAutomacao\Shortcuts"
            Name="Desktop"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- ==================================================
       Atalho: 'Enviar para' (opcional, off por padrao)
       ================================================== -->
  <Fragment>
    <ComponentGroup Id="AppShortcutsSendTo" Directory="SendToFolder">
      <Component Id="ShortcutSendTo" Guid="*">
        <Shortcut
            Id="ShortcutSendToLnk"
            Name="Ferias Automacao"
            Description="Envia uma planilha .xlsx pro Ferias Automacao"
            Target="[System64Folder]WindowsPowerShell\v1.0\powershell.exe"
            Arguments='-ExecutionPolicy Bypass -WindowStyle Hidden -File "[INSTALLFOLDER]gui.ps1"'
            WorkingDirectory="INSTALLFOLDER"
            Icon="AppIcon.exe"
            IconIndex="0" />
        <RegistryValue
            Root="HKCU"
            Key="Software\FeriasAutomacao\Shortcuts"
            Name="SendTo"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
